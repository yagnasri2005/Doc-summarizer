# Environment Configuration for Document Summarizer

# Flask Settings
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here

# Summarization Model Selection
# Options: 'openai', 'huggingface', 'local'
SUMMARIZER_MODEL=huggingface

# OpenAI Settings (if using OpenAI model)
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_API_BASE=https://api.openai.com/v1

# Hugging Face Settings (if using Hugging Face model)
HUGGINGFACE_API_KEY=hf_your-token-here
HUGGINGFACE_MODEL=facebook/bart-large-cnn

# Google Settings (for future integration)
GOOGLE_API_KEY=your-google-api-key-here

# Application Settings
MAX_FILE_SIZE_MB=50
DEFAULT_SUMMARY_LENGTH=medium

# Logging
LOG_LEVEL=INFO
LOG_FILE=app.log
